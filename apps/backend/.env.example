# SmartSupport AI Platform - Environment Configuration
# Copy this file to .env and fill in the values

APP_ENV=development
APP_NAME=SmartSupport AI Platform
API_V1_PREFIX=/api/v1
DEBUG=true

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=smartsupport
POSTGRES_PASSWORD=smartsupport
POSTGRES_DB=smartsupport
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ChromaDB - http for external server, embedded for in-process
CHROMA_MODE=http
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# OpenAI
AI_PROVIDER=openai
AI_API_KEY=changeme
AI_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536

# Chat completion settings
AI_CHAT_MODEL=gpt-4o-mini
AI_CHAT_TEMPERATURE=0.2
CHAT_RETRIEVAL_TOP_K=4

# Document storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Embedding settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
