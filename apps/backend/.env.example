APP_ENV=development
APP_NAME=Orin
# Whoever registers with this email becomes an admin automatically. Set this before your
# own first registration; further admins are promoted through the admin dashboard.
FIRST_ADMIN_EMAIL=
API_V1_PREFIX=/api/v1
DEBUG=true

# Generate with: openssl rand -hex 32
SECRET_KEY=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_USER=orin
POSTGRES_PASSWORD=orin
POSTGRES_DB=orin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

CHROMA_HOST=chromadb
CHROMA_PORT=8000

AI_PROVIDER=gemini
# Get a free Gemini API key at https://aistudio.google.com/apikey
AI_API_KEY=changeme
AI_MODEL=models/gemini-embedding-001
AI_EMBEDDING_DIMENSIONS=3072

# Chat completion settings
AI_CHAT_MODEL=gemini-2.5-flash
AI_CHAT_TEMPERATURE=0.2
CHAT_RETRIEVAL_TOP_K=4

# Document storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Embedding settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# CORS settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000
